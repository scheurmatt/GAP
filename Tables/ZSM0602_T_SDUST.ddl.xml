@EndUserText.label : 'Stardust'
@AbapCatalog.enhancement.category : #NOT_EXTENSIBLE
@AbapCatalog.tableCategory : #TRANSPARENT
@AbapCatalog.deliveryClass : #A
@AbapCatalog.dataMaintenance : #ALLOWED
define table zsm0602_t_sdust {

  key client        : abap.clnt not null;
  key stardust_uuid : sysuuid_x16 not null;
  collection_uuid   : sysuuid_x16;
  color             : abap.char(20);
  weight            : abap.dec(10,2);
  matter_state      : abap.char(10);
  @Semantics.amount.currencyCode : 'zsm0602_t_sdust.currency_code'
  value             : abap.curr(15,2);
  currency_code     : abap.cuky;
  owner_uuid        : sysuuid_x16;

}
